<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- ═══════════════════════════════════════════════════════════
         1. TRACKING
         MetraShop no realiza seguimiento entre apps de terceros.
         ═══════════════════════════════════════════════════════════ -->
    <key>NSPrivacyTracking</key>
    <false/>

    <!-- ═══════════════════════════════════════════════════════════
         2. TRACKING DOMAINS
         Sin dominios de tracking porque NSPrivacyTracking = false.
         ═══════════════════════════════════════════════════════════ -->
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- ═══════════════════════════════════════════════════════════
         3. REQUIRED REASON APIs
         APIs de iOS con razón obligatoria declarada por Apple.
         ═══════════════════════════════════════════════════════════ -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>

        <!-- UserDefaults — usado por shared_preferences, Firebase SDK y Google Sign-In -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- CA92.1: lectura/escritura de UserDefaults para funcionalidad propia de la app -->
                <string>CA92.1</string>
            </array>
        </dict>

        <!-- File timestamp — usado por Isar (base de datos local) -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- DDA9.1: el funcionamiento de la app depende de cuándo se modificó un archivo -->
                <string>DDA9.1</string>
            </array>
        </dict>

        <!-- System boot time — usado por Firebase Analytics para medir tiempo relativo -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategorySystemBootTime</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- 35F9.1: calcular tiempo transcurrido desde el inicio del sistema -->
                <string>35F9.1</string>
            </array>
        </dict>

        <!-- Disk space — usado por Isar al crear/verificar la base de datos local -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryDiskSpace</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- 85F4.1: verificar espacio disponible antes de escribir datos en disco -->
                <string>85F4.1</string>
            </array>
        </dict>

    </array>

    <!-- ═══════════════════════════════════════════════════════════
         4. DATOS RECOPILADOS
         Solo se declaran los datos que la app recopila y envía
         fuera del dispositivo. Datos usados únicamente on-device
         (Isar local) no se declaran.
         ═══════════════════════════════════════════════════════════ -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array>

        <!-- Nombre — perfil de usuario en Supabase -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeName</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Email — autenticación con Supabase -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeEmailAddress</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- User ID — identificador en Supabase / Firebase -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeUserID</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Ubicación precisa — geolocator para mostrar proveedores cercanos en el mapa -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypePreciseLocation</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <false/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Fotos — el usuario puede subir fotos de su negocio como proveedor -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypePhotosorVideos</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Datos de uso — Firebase Analytics (sesiones, pantallas visitadas) -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeOtherUsageData</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <false/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAnalytics</string>
            </array>
        </dict>

        <!-- Historial de compras — RevenueCat (suscripciones premium) -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypePurchaseHistory</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

    </array>

</dict>
</plist>
