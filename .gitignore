# Environment variables - SEGURIDAD CRÍTICA
.env
.env.dev
.env.prod
.env.local
.env.production
.env.*.local

# iOS secrets - SEGURIDAD CRÍTICA
ios/Flutter/Secret.xcconfig
ios/Runner/GoogleService-Info.plist
ios/GoogleService-Info.plist

# Android Firebase - SEGURIDAD CRÍTICA
android/app/google-services.json

# Nota: app_secrets.dart es seguro subir porque solo lee del .env
# Los secretos reales están en .env (que sí está ignorado)

# Android keystore - SEGURIDAD CRÍTICA
android/key.properties
**/*.keystore
**/*.jks

# iOS provisioning
*.mobileprovision
*.p12
*.cer

# Documentación local (no necesaria en repo)
*.md

# SQL migrations (local only)
*.sql

# Backups y archivos temporales
.backup_firebase_old/
.claude/

# Scripts locales
scripts/

# Supabase local (migraciones y config)
supabase/

